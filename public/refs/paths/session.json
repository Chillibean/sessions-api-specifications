{
  "get": {
    "summary": "Get active status of current user session",
    "description": "Get active status of current user session",
    "operationId": "getSession",
    "tags": [
      "Sessions"
    ],
    "security": [
      {
        "userSessionKey": [],
        "chillipharmSession": []
      }
    ],
    "responses": {
      "200": {
        "description": "OK",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "../components/schemas/Active.json"
            }
          }
        }
      },
      "401": {
        "$ref": "../components/responses/Unauthorized.json"
      },
      "404": {
        "$ref": "../components/responses/BadRequest.json"
      },
      "500": {
        "$ref": "../components/responses/InternalServerError.json"
      }
    }
  },
  "delete": {
    "summary": "End current user session",
    "description": "End current user session",
    "operationId": "deleteSession",
    "tags": [
      "Sessions"
    ],
    "security": [
      {
        "userSessionKey": [],
        "chillipharmSession": []
      }
    ],
    "requestBody": {
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "authenticity_token": {
                "$ref": "../components/schemas/AuthenticityToken.json"
              }
            },
            "required": [
              "authenticity_token"
            ],
            "additionalProperties": false
          }
        }
      }
    },
    "responses": {
      "200": {
        "description": "OK",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "message": {
                  "type": "string",
                  "description": "The active status of the current user session",
                  "example": "User session is active"
                },
                "logout_url": {
                  "type": "string",
                  "description": "The URL to log out the current user session",
                  "example": "https://dummy.auth0.com/v2/logout"
                }
              },
              "required": [
                "message",
                "logout_url"
              ]
            }
          }
        }
      },
      "401": {
        "$ref": "../components/responses/Unauthorized.json"
      },
      "404": {
        "$ref": "../components/responses/BadRequest.json"
      },
      "500": {
        "$ref": "../components/responses/InternalServerError.json"
      }
    }
  }
}
